---
// FILE: Layout.astro
// Purpose: Shared metadata, navigation, theme tokens, and footer for Scient's marketing pages.
// Layer: Marketing layout
// Depends on: release repo metadata from ../lib/releases and bundled Scient brand assets.

import "@fontsource-variable/dm-sans";
interface Props {
  title?: string;
  description?: string;
  theme?: "dark" | "light";
  robots?: string;
}

const {
  title = "Scient",
  description = "One intelligent workspace for every stage of research.",
  theme = "dark",
  robots,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, "https://scientfactory.com");
const brandIcon = theme === "light" ? "/scient-symbol.svg" : "/icon.png";
const currentPath = Astro.url.pathname;

const primaryLinks = [
  { href: "/about", label: "About", active: currentPath === "/about" },
  { href: "/docs", label: "Docs", active: currentPath.startsWith("/docs") },
] as const;
---

<html lang="en" data-theme={theme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <meta name="theme-color" content={theme === "light" ? "#ffffff" : "#09090b"} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ScientFactory" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon-16x16.png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>

    <div class="page">
      <nav class="nav" aria-label="Primary navigation">
        <a href="/" class="nav-brand" aria-label="Scient home">
          <img src={brandIcon} alt="" class="nav-icon" width="42" height="45" />
          <span class="nav-wordmark">ScientFactory</span>
        </a>
        <div class="nav-links">
          {primaryLinks.map((link) => (
            <a href={link.href} class="nav-link" aria-current={link.active ? "page" : undefined}>
              {link.label}
            </a>
          ))}
        </div>
      </nav>

      <main id="main-content" class="main">
        <slot />
      </main>

      <footer class="footer">
        <span class="footer-copy">&copy; {new Date().getFullYear()} ScientFactory</span>
        <div class="footer-links">
          <button type="button" class="footer-link-button" data-analytics-settings>
            Analytics settings
          </button>
          <a href="/privacy">Privacy</a>
        </div>
      </footer>
    </div>

    <aside class="analytics-consent" data-analytics-consent hidden aria-labelledby="analytics-consent-title">
      <div class="analytics-consent-copy">
        <strong id="analytics-consent-title">Help us improve Scient</strong>
        <p>
          Allow first-party product analytics to connect visits, downloads, and returning sessions.
          We do not collect research content. <a href="/privacy">Learn more</a>
        </p>
      </div>
      <div class="analytics-consent-actions">
        <button type="button" class="analytics-consent-secondary" data-consent-level="essential">
          Essential only
        </button>
        <button type="button" class="analytics-consent-primary" data-consent-level="product">
          Allow analytics
        </button>
      </div>
    </aside>

    <script>
      interface SiteEventPayload {
        readonly event_name: "page_viewed" | "outbound_link_clicked";
        readonly page_path: string;
        readonly destination_url?: string;
        readonly session_id?: string;
      }

      const eventEndpoint = "/api/events";
      const consentEndpoint = "/api/consent";
      const consentCookieName = "sf_analytics";
      const sessionCookieName = "sf_session";
      const sessionStorageKey = "scientfactory:analytics-session:v1";
      const pagePath = window.location.pathname;

      function consentLevel(): "essential" | "product" | null {
        const encoded = document.cookie
          .split(";")
          .map((part) => part.trim())
          .find((part) => part.startsWith(`${consentCookieName}=`))
          ?.slice(consentCookieName.length + 1);
        return encoded === "essential" || encoded === "product" ? encoded : null;
      }

      function analyticsSessionId(): string | undefined {
        if (consentLevel() !== "product") return undefined;
        try {
          const existing = sessionStorage.getItem(sessionStorageKey);
          if (existing?.startsWith("session:")) {
            document.cookie = `${sessionCookieName}=${existing}; Path=/; SameSite=Lax${window.location.protocol === "https:" ? "; Secure" : ""}`;
            return existing;
          }
          const created = `session:${crypto.randomUUID()}`;
          sessionStorage.setItem(sessionStorageKey, created);
          document.cookie = `${sessionCookieName}=${created}; Path=/; SameSite=Lax${window.location.protocol === "https:" ? "; Secure" : ""}`;
          return created;
        } catch {
          return `session:${crypto.randomUUID()}`;
        }
      }

      function sendSiteEvent(payload: SiteEventPayload): void {
        const body = JSON.stringify(payload);
        if (
          typeof navigator.sendBeacon === "function" &&
          navigator.sendBeacon(eventEndpoint, new Blob([body], { type: "application/json" }))
        ) {
          return;
        }

        void fetch(eventEndpoint, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body,
          keepalive: true,
          credentials: "same-origin",
        }).catch(() => {
          // Measurement must never interrupt navigation or the page experience.
        });
      }

      const initialSessionId = analyticsSessionId();
      sendSiteEvent({
        event_name: "page_viewed",
        page_path: pagePath,
        ...(initialSessionId ? { session_id: initialSessionId } : {}),
      });

      const consentPanel = document.querySelector<HTMLElement>("[data-analytics-consent]");
      const settingsButtons = document.querySelectorAll<HTMLButtonElement>("[data-analytics-settings]");
      const consentButtons = document.querySelectorAll<HTMLButtonElement>("[data-consent-level]");

      function showConsentPanel(): void {
        if (!consentPanel) return;
        consentPanel.hidden = false;
        consentPanel.querySelector<HTMLButtonElement>("button")?.focus({ preventScroll: true });
      }

      function hideConsentPanel(): void {
        if (consentPanel) consentPanel.hidden = true;
      }

      if (consentLevel() === null && consentPanel) consentPanel.hidden = false;
      settingsButtons.forEach((button) => button.addEventListener("click", showConsentPanel));
      consentButtons.forEach((button) => {
        button.addEventListener("click", async () => {
          const level = button.dataset.consentLevel;
          if (level !== "essential" && level !== "product") return;
          consentButtons.forEach((candidate) => (candidate.disabled = true));
          try {
            const result = await fetch(consentEndpoint, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              credentials: "same-origin",
              body: JSON.stringify({ level }),
            });
            if (!result.ok) throw new Error("Consent update failed");
            if (level === "essential") {
              try {
                sessionStorage.removeItem(sessionStorageKey);
                document.cookie = `${sessionCookieName}=; Path=/; Max-Age=0; SameSite=Lax${window.location.protocol === "https:" ? "; Secure" : ""}`;
              } catch {
                // Storage can be unavailable in hardened browsers.
              }
            } else {
              analyticsSessionId();
            }
            consentButtons.forEach((candidate) => (candidate.disabled = false));
            hideConsentPanel();
          } catch {
            consentButtons.forEach((candidate) => (candidate.disabled = false));
          }
        });
      });

      document.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        const link = target.closest<HTMLAnchorElement>("a[href]");
        if (!link) return;

        let destination: URL;
        try {
          destination = new URL(link.href, window.location.href);
        } catch {
          return;
        }

        if (
          destination.origin === window.location.origin ||
          (destination.protocol !== "https:" && destination.protocol !== "http:")
        ) {
          return;
        }

        const sessionId = analyticsSessionId();
        sendSiteEvent({
          event_name: "outbound_link_clicked",
          page_path: pagePath,
          destination_url: destination.href,
          ...(sessionId ? { session_id: sessionId } : {}),
        });
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --surface: #ffffff;
    --surface-muted: #f6f7f8;
    --ink: #111111;
    --ink-muted: #474747;
    --ink-dim: #6c6c70;
    --burgundy: #541b1d;
    --burgundy-soft: #fbf6f6;
    --slate: #526687;
    --slate-soft: #f5f7fb;
    --line: #dedfe2;
    --focus-ring: rgba(82, 102, 135, 0.3);
    --radius-sm: 6px;
    --ease-out: cubic-bezier(0.22, 1, 0.36, 1);
    --page-gutter: clamp(1.25rem, 5vw, 5.75rem);
    --bg: var(--surface);
    --fg: var(--ink);
    --fg-muted: var(--ink-muted);
    --fg-dim: var(--ink-dim);
    --border: var(--line);
    color-scheme: light;
  }

  html[data-theme="dark"] {
    --surface: #09090b;
    --surface-muted: #131316;
    --ink: #fafafa;
    --ink-muted: #a1a1aa;
    --ink-dim: #71717a;
    --line: rgba(255, 255, 255, 0.08);
    --focus-ring: rgba(250, 250, 250, 0.25);
    color-scheme: dark;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    min-width: 320px;
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
    overflow-x: hidden;
    background: var(--surface);
    color: var(--ink);
    font-family: "DM Sans Variable", "DM Sans", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-optical-sizing: auto;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  input,
  textarea,
  select {
    font: inherit;
  }

  img,
  svg {
    display: block;
    max-width: 100%;
  }

  .skip-link {
    position: fixed;
    z-index: 100;
    top: 0.75rem;
    left: 0.75rem;
    padding: 0.65rem 0.9rem;
    border-radius: var(--radius-sm);
    background: var(--ink);
    color: var(--surface);
    transform: translateY(-160%);
    transition: transform 180ms var(--ease-out);
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  @keyframes reveal-up {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes geometry-in {
    from {
      opacity: 0;
      transform: translate3d(3rem, -1rem, 0) scale(1.02);
    }
    to {
      opacity: var(--geometry-opacity, 0.1);
      transform: translate3d(0, 0, 0) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }

    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      scroll-behavior: auto !important;
    }
  }
</style>

<style>
  .page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow: clip;
  }

  .nav {
    position: relative;
    z-index: 10;
    min-height: 7rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.75rem clamp(3rem, 3.4vw, 3.25rem);
  }

  .nav-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.78rem;
    border-radius: var(--radius-sm);
  }

  .nav-icon {
    width: 3rem;
    height: 3.2rem;
    object-fit: contain;
    flex: 0 0 auto;
    transition: transform 260ms var(--ease-out);
  }

  html[data-theme="dark"] .nav-icon {
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-sm);
  }

  .nav-wordmark {
    font-size: 1.9rem;
    font-weight: 500;
    letter-spacing: -0.045em;
  }

  .nav-brand:hover .nav-icon {
    transform: translateY(-1px) scale(1.025);
  }

  .nav-brand:focus-visible,
  .nav-link:focus-visible,
  .footer-links a:focus-visible {
    outline: 3px solid var(--focus-ring);
    outline-offset: 5px;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: clamp(1.15rem, 2.1vw, 2.15rem);
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0;
    border-bottom: 1px solid transparent;
    color: var(--ink);
    font-size: 1rem;
    transition: border-color 220ms var(--ease-out), color 220ms var(--ease-out);
  }

  .nav-link:hover,
  .nav-link[aria-current="page"] {
    color: var(--burgundy);
    border-bottom-color: currentColor;
  }

  .main {
    flex: 1;
    min-width: 0;
  }

  .footer {
    min-height: 5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.5rem var(--page-gutter);
    border-top: 1px solid var(--line);
    color: var(--ink-dim);
    font-size: 0.82rem;
  }

  .footer-links {
    display: flex;
    gap: 1.25rem;
  }

  .footer-link-button {
    appearance: none;
    padding: 0;
    border: 0;
    background: transparent;
    color: inherit;
    cursor: pointer;
  }

  .footer-links a,
  .footer-link-button {
    transition: color 220ms var(--ease-out);
  }

  .footer-links a:hover,
  .footer-link-button:hover {
    color: var(--ink);
  }

  .footer-link-button:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 0.25rem;
  }

  .analytics-consent {
    position: fixed;
    z-index: 50;
    right: clamp(1rem, 3vw, 2rem);
    bottom: clamp(1rem, 3vw, 2rem);
    width: min(35rem, calc(100vw - 2rem));
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 1.25rem;
    padding: 1rem 1.1rem;
    border: 1px solid var(--line);
    border-radius: 0.75rem;
    background: color-mix(in srgb, var(--surface) 96%, transparent);
    box-shadow: 0 1rem 3rem rgba(0, 0, 0, 0.12);
    backdrop-filter: blur(18px);
  }

  .analytics-consent[hidden] {
    display: none;
  }

  .analytics-consent-copy strong {
    display: block;
    margin-bottom: 0.2rem;
    font-size: 0.92rem;
    font-weight: 600;
  }

  .analytics-consent-copy p {
    margin: 0;
    color: var(--ink-muted);
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .analytics-consent-copy a {
    text-decoration: underline;
    text-underline-offset: 0.16em;
  }

  .analytics-consent-actions {
    display: flex;
    gap: 0.5rem;
  }

  .analytics-consent-actions button {
    min-height: 2.25rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--line);
    border-radius: 0.45rem;
    cursor: pointer;
    font-size: 0.78rem;
    white-space: nowrap;
    transition: transform 180ms var(--ease-out), background-color 180ms var(--ease-out);
  }

  .analytics-consent-actions button:hover:not(:disabled) {
    transform: translateY(-1px);
  }

  .analytics-consent-secondary {
    background: var(--surface);
    color: var(--ink);
  }

  .analytics-consent-primary {
    border-color: var(--burgundy) !important;
    background: var(--burgundy);
    color: #fff;
  }

  .analytics-consent-actions button:disabled {
    cursor: wait;
    opacity: 0.6;
  }

  @media (max-width: 640px) {
    .nav {
      min-height: 5.5rem;
      padding-block: 1.15rem;
      padding-inline: var(--page-gutter);
    }

    .nav-brand {
      gap: 0.7rem;
    }

    .nav-icon {
      width: 2.05rem;
      height: 2.2rem;
    }

    .nav-wordmark {
      font-size: 1.2rem;
    }

    .nav-links {
      gap: 1.1rem;
    }

    .nav-link {
      font-size: 0.9rem;
    }

    .footer {
      align-items: flex-start;
      flex-direction: column;
      padding-block: 1.5rem;
    }

    .footer-links {
      flex-wrap: wrap;
      gap: 0.75rem 1.1rem;
    }

    .analytics-consent {
      grid-template-columns: 1fr;
      gap: 0.85rem;
    }

    .analytics-consent-actions {
      width: 100%;
    }

    .analytics-consent-actions button {
      flex: 1;
    }
  }
</style>
